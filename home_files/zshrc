# cspell:disable
# ~/.zshrc
#
# Role     : Interactive zsh setup — history, completion, keybindings, tool init
# Loaded   : INTERACTIVE zsh shells only
# Order    : .zshenv → [.zprofile] → ❯ .zshrc → [.zlogin]
# Sources  : ~/.shell.environment (guarded), ~/.aliases, _load_common_commands
# Notes    : Interactive-only — safe to print output / configure the TTY

# Source shell.environment if exist
if [ -f ~/.shell.environment ]; then
	source ~/.shell.environment
fi

# Source Aliases file
if [ -f ~/.aliases ]; then
	source ~/.aliases
fi

# Lines configured by zsh-newuser-install
HISTFILE=~/.histfile
HISTSIZE=1000
SAVEHIST=1000
setopt beep extendedglob nomatch notify
unsetopt autocd
bindkey -e

# End of lines configured by zsh-newuser-install
# The following lines were added by compinstall
zstyle :compinstall filename '~/.zshrc'

autoload -Uz compinit
compinit
# End of lines added by compinstall

# Load common commands (starship, bat, zoxide, etc.)
_load_common_commands zsh
