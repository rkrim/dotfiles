// Zed settings
// cspell:disable
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
	"cli_default_open_behavior": "new_window",
 "outline_panel": {
  "dock": "right"
 },
 "edit_predictions": {
		"provider": "copilot"
	},
	"on_last_window_closed": "platform_default",
	"when_closing_with_no_tabs": "keep_window_open",
	"agent_servers": {
		"gemini": {
   "type": "registry"
  },
  "codex-acp": {
   "type": "registry"
  },
  "claude-acp": {
			"type": "registry",
			"default_config_options": {
				"model": "opus",
    "mode": "plan"
			},
			"favorite_config_option_values": {
				"model": [
     "default",
     "opus"
    ],
    "mode": ["plan"]
			}
		},
		"opencode": {
			"favorite_models": ["opencode/kimi-k2.5-free"],
			"type": "registry"
		}
	},
	"context_servers": {
		"browser-tools-context-server": {
   "enabled": true,
			"remote": false,
			"settings": {}
		},
		"next-devtools": {
   "command": "npx",
			"args": ["-y", "next-devtools-mcp@latest"],
			"env": {}
		},
		"shadcn": {
   "enabled": true,
			"command": "npx",
			"args": ["shadcn@latest", "mcp"]
		},
		"posthog": {
   "enabled": true,
			"url": "https://mcp.posthog.com/mcp",
			"headers": {
				"Authorization": "Bearer undefined"
			}
		}
	},
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "One Dark"
	},
	"icon_theme": {
		"mode": "dark",
		"light": "Symbols Icon Theme",
		"dark": "Symbols Icon Theme"
	},
	"use_system_window_tabs": false,
	"ui_font_family": ".ZedSans",
	"ui_font_size": 17.0,
	"buffer_font_size": 16.0,
	"hard_tabs": true,
	"tab_size": 2,
	"show_wrap_guides": true,
	"wrap_guides": [90],
	"preferred_line_length": 90,
	"indent_guides": {
		"coloring": "indent_aware"
	},
	"title_bar": {
		"show_branch_status_icon": true,
  "show_menus": true
	},
	"tab_bar": {
		"show": true,
		"show_tab_bar_buttons": true,
		"show_nav_history_buttons": true
	},
	"tabs": {
		"show_close_button": "always",
		"show_diagnostics": "all",
		"close_position": "right",
		"file_icons": true,
		"git_status": true
	},
	"toolbar": {
		"selections_menu": true,
		"agent_review": true,
		"code_actions": true,
		"breadcrumbs": true,
		"quick_actions": true
	},
	"project_panel": {
		"dock": "right",
		"folder_icons": true,
		"file_icons": true,
		"git_status": true,
		"hide_root": false,
		"hide_hidden": false,
		"hide_gitignore": false,
		"entry_spacing": "comfortable"
	},
	"git": {
		"git_gutter": "tracked_files",
		"blame": {
			"show_avatar": true
		},
		"branch_picker": {
			"show_author_name": true
		},
		"hunk_style": "staged_hollow",
		"path_style": "file_name_first",
		"inline_blame": {
			"show_commit_summary": true,
			"enabled": true
		}
	},
	"git_panel": {
		"tree_view": true,
		"collapse_untracked_diff": false,
		"sort_by_path": false,
		"status_style": "icon",
		"default_width": 360.0,
		"dock": "right",
		"button": true
	},
	"notification_panel": {
		"default_width": 360.0
	},
	"terminal": {
		"dock": "bottom",
		"shell": "system",
		"font_family": "FiraMono Nerd Font",
		"font_size": 16.0,
		"cursor_shape": "bar",
		"blinking": "terminal_controlled",
		"max_scroll_history_lines": 20000,
		"scrollbar": {
			"show": "system"
		},
		"toolbar": {
			"breadcrumbs": true
		}
	},
	"minimap": {
		"show": "auto"
	},
	"diagnostics_max_severity": "all",
	"diagnostics": {
		"button": true,
		"inline": {
			"min_column": 0,
			"padding": 4,
			"update_debounce_ms": 150,
			"enabled": true
		}
	},
	"disable_ai": false,
	"show_edit_predictions": true,
	"agent": {
		"favorite_models": [
			{
				"provider": "openrouter",
				"model": "anthropic/claude-opus-4.5"
			}
		],
		"default_model": {
			"provider": "openrouter",
			"model": "anthropic/claude-opus-4.5"
		},
		"show_turn_stats": true,
		"dock": "left",
		"button": true,
		"default_width": 360.0,
		"message_editor_min_lines": 5,
		"play_sound_when_agent_done": "always",
		"notify_when_agent_waiting": "primary_screen",
		"model_parameters": []
	},
	"collaboration_panel": {
		"dock": "right",
  "button": false
	},
	"format_on_save": "off",
	"prettier": {
		"allowed": true
	},
	"formatter": {
		"external": {
			"command": "prettier",
			"arguments": ["--stdin-filepath", "{buffer_path}"]
		}
	},
	"languages": {
		"JSON": {
			"formatter": {
				"external": {
					"command": "prettier",
					"arguments": ["--stdin-filepath", "{buffer_path}", "--parser", "json"]
				}
			}
		}
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	}
}
