# shellcheck shell=bash
# cspell:disable
# ~/.bash_profile
#
# Role     : Login bash entry point; unifies login + interactive config
# Loaded   : LOGIN bash shells — /etc/profile, then the FIRST that exists of
#            ~/.bash_profile, ~/.bash_login, ~/.profile (macOS terms are login)
# Order    : /etc/profile → ❯ .bash_profile → .bashrc
# Sources  : ~/.shell.environment (guarded), ~/.bashrc
# Notes    : Sources ~/.bashrc so login & non-login shells share one config

# Source shell.environment if exist
if [ -f ~/.shell.environment ]; then
	source ~/.shell.environment
fi

# About All other things
# Source ~/.bashrc if exist (not automatically sourced in non-login shells)
if [ -f ~/.bashrc ]; then
	source ~/.bashrc
fi
